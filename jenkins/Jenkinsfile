pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'clouddeployx'
        DOCKER_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Clone Repository') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo 'Installing dependencies...'
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
                sh 'npm test'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image...'
                sh "docker build -f docker/Dockerfile -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying...'
                sh "docker stop ${DOCKER_IMAGE}-app || true"
                sh "docker rm ${DOCKER_IMAGE}-app || true"
                sh "docker run -d -p 3000:3000 --name ${DOCKER_IMAGE}-app ${DOCKER_IMAGE}:${DOCKER_TAG}"
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}